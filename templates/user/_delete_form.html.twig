<form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Confirmer la suppression de cet utilisateur ?');" style="display: inline; margin: 0;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
    <button class="button outline small" type="submit" aria-label="Supprimer l'utilisateur" title="Supprimer">
        {{ ux_icon('trash-2') }}
    </button>
</form>
