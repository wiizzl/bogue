{% extends 'base.html.twig' %}

{% block title %}Utilisateur{% endblock %}

{% block body %}
    <section>
        <h2>Fiche utilisateur</h2>
        <p>{{ user.firstName }} {{ user.lastName }}</p>
    </section>

    <section>
        <table>
            <tbody>
                <tr>
                    <th>Email</th>
                    <td>{{ user.email }}</td>
                </tr>
                <tr>
                    <th>Rôles</th>
                    <td>
                        {% set roleLabels = user.userRoles|map(role => role.label)|filter(label => label is not empty) %}
                        {{ roleLabels is not empty ? roleLabels|join(', ') : 'Utilisateur' }}
                    </td>
                </tr>
            </tbody>
        </table>
    </section>

    <section>
        <a href="{{ path('app_user_edit', {'id': user.id}) }}">Modifier</a>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_user_index') }}">Retour a la liste</a>
        {% else %}
            <a href="{{ path('app_home_index') }}">Retour</a>
        {% endif %}
    </section>
{% endblock %}
