{% extends 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block body %}
    <section>
        <p><a href="{{ path('app_user_new') }}">Ajouter un utilisateur</a></p>
    </section>

    <section class="table">
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Rôle</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ user.fullName }}</td>
                    <td>{{ user.email }}</td>
                    <td>
                        {{ user.role.label }}
                    </td>
                    <td class="actions-cell">
                        <a href="{{ path('app_user_show', {'id': user.id}) }}" class="button outline small" aria-label="Voir l'utilisateur" title="Voir">
                            {{ ux_icon('eye') }}
                        </a>
                        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="button outline small" aria-label="Modifier l'utilisateur" title="Modifier">
                            {{ ux_icon('pen-line') }}
                        </a>
                        {% if app.user and app.user.id != user.id %}
                            {{ include('_delete_form.html.twig', {
                                entity: user,
                                route: 'app_user_delete',
                                confirm_message: 'Confirmer la suppression de cet utilisateur ?',
                                aria_label: 'Supprimer l\'utilisateur'
                            }) }}
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">Aucun utilisateur enregistré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
