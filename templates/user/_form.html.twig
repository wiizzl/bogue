{{ form_start(form) }}
    <fieldset>
        <legend>Informations utilisateur</legend>

        <label data-field for="{{ form.email.vars.id }}">
            {{ form.email.vars.label }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </label>

        <label data-field for="{{ form.password.vars.id }}">
            {{ form.password.vars.label }}
            {{ form_widget(form.password, {'attr': {'aria-describedby': form.password.vars.id ~ '_hint'}}) }}
            <small id="{{ form.password.vars.id }}_hint" data-hint>Renseignez un mot de passe fort.</small>
            {{ form_errors(form.password) }}
        </label>

        <label data-field for="{{ form.firstName.vars.id }}">
            {{ form.firstName.vars.label }}
            {{ form_widget(form.firstName) }}
            {{ form_errors(form.firstName) }}
        </label>

        <label data-field for="{{ form.lastName.vars.id }}">
            {{ form.lastName.vars.label }}
            {{ form_widget(form.lastName) }}
            {{ form_errors(form.lastName) }}
        </label>

        {% if form.userRoles is defined %}
            <div data-field>
                {{ form_label(form.userRoles) }}
                <div>
                    {% for roleField in form.userRoles %}
                        <label for="{{ roleField.vars.id }}">
                            {{ form_widget(roleField) }}
                            <span>{{ roleField.vars.label }}</span>
                        </label>
                    {% endfor %}
                </div>
                {{ form_errors(form.userRoles) }}
            </div>
        {% endif %}
    </fieldset>
    <button type="submit">{{ button_label|default('Enregistrer') }}</button>
{{ form_end(form) }}
