{% extends 'base.html.twig' %}

{% block title %}Stages{% endblock %}

{% block body %}
    <section>
        <h2>Liste des stages</h2>
        {% if is_granted('ROLE_ADMIN') %}
            <p><a href="{{ path('app_internship_new') }}">Ajouter un stage</a></p>
        {% endif %}
    </section>

    <section>
        <table>
            <thead>
                <tr>
                    <th>Étudiant</th>
                    <th>Entreprise</th>
                    <th>Durée</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for internship in internships %}
                <tr>
                    <td>{{ internship.student.fullName }}</td>
                    <td>{{ internship.company.name }}</td>
                    {% if internship.startDate and internship.endDate %}
                        <td title="Du {{ internship.startDate|date('d/m/Y') }} au {{ internship.endDate|date('d/m/Y') }}">
                            {{ internship.durationInWeeks }} semaine{{ internship.durationInWeeks > 1 ? 's' : '' }}
                        </td>
                    {% else %}
                        <td>-</td>
                    {% endif %}
                    <td>
                        <a href="{{ path('app_internship_show', {'id': internship.id}) }}" aria-label="Voir le stage" title="Voir">
                            {{ ux_icon('eye') }}
                            <span>Voir</span>
                        </a>
                        {% if is_granted('EDIT_INTERNSHIP', internship) %}
                            <a href="{{ path('app_internship_edit', {'id': internship.id}) }}" aria-label="Modifier le stage" title="Modifier">
                                {{ ux_icon('pen-line') }}
                                <span>Modifier</span>
                            </a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            {{ include('internship/_delete_form.html.twig', {'internship': internship}) }}
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">Aucun stage enregistré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
