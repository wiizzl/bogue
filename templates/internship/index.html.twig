{% extends 'base.html.twig' %}

{% block title %}Stages{% endblock %}

{% block body %}
    <section>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_internship_new') }}">Ajouter un stage</a>
        {% endif %}
    </section>

    <section class="table">
        <table>
            <thead>
                <tr>
                    <th>Étudiant</th>
                    <th>Entreprise</th>
                    <th>Durée</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for internship in internships %}
                <tr>
                    <td>{{ internship.student.fullName }}</td>
                    <td>{{ internship.company.name }}</td>
                    {% if internship.startDate and internship.endDate %}
                        <td title="Du {{ internship.startDate|date('d/m/Y') }} au {{ internship.endDate|date('d/m/Y') }}">
                            {{ internship.durationInWeeks }} semaine{{ internship.durationInWeeks > 1 ? 's' : '' }}
                        </td>
                    {% else %}
                        <td>-</td>
                    {% endif %}
                    <td style="display: flex; align-items: center; gap: var(--space-2);">
                        <a href="{{ path('app_internship_show', {'id': internship.id}) }}" class="button outline small" aria-label="Voir le stage" title="Voir">
                            {{ ux_icon('eye') }}
                        </a>
                        {% if is_granted('EDIT_INTERNSHIP', internship) %}
                            <a href="{{ path('app_internship_edit', {'id': internship.id}) }}" class="button outline small" aria-label="Modifier le stage" title="Modifier">
                                {{ ux_icon('pen-line') }}
                            </a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            {{ include('internship/_delete_form.html.twig', {'internship': internship}) }}
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">Aucun stage enregistré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>

    <section style="padding-top: var(--space-4);">
        <nav aria-label="Pagination">
            <menu class="buttons">
                <li>
                    {% if current_page > 1 %}
                        <a href="{{ path('app_internship_index', {'page': current_page - 1}) }}" class="button outline small">&larr;</a>
                    {% else %}
                        <a class="button outline small" aria-disabled="true">&larr;</a>
                    {% endif %}
                </li>

                {% for i in 1..pages_count %}
                    <li>
                        {% if i == current_page %}
                            <a href="{{ path('app_internship_index', {'page': i}) }}" class="button small" aria-current="page">{{ i }}</a>
                        {% else %}
                            <a href="{{ path('app_internship_index', {'page': i}) }}" class="button outline small">{{ i }}</a>
                        {% endif %}
                    </li>
                {% endfor %}

                <li>
                    {% if current_page < pages_count %}
                        <a href="{{ path('app_internship_index', {'page': current_page + 1}) }}" class="button outline small">&rarr;</a>
                    {% else %}
                        <a class="button outline small" aria-disabled="true">&rarr;</a>
                    {% endif %}
                </li>
            </menu>
        </nav>
    </section>
{% endblock %}
