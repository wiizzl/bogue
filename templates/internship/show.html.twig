{% extends 'base.html.twig' %}

{% block title %}Internship{% endblock %}

{% block body %}
    <h1>Internship</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ internship.id }}</td>
            </tr>
            <tr>
                <th>StartDate</th>
                <td>{{ internship.startDate ? internship.startDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>EndDate</th>
                <td>{{ internship.endDate ? internship.endDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Remarks</th>
                <td>{{ internship.remarks }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_internship_index') }}">back to list</a>

    <a href="{{ path('app_internship_edit', {'id': internship.id}) }}">edit</a>

    {{ include('internship/_delete_form.html.twig') }}
{% endblock %}
