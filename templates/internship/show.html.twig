{% extends 'base.html.twig' %}

{% block title %}Détail du Stage{% endblock %}

{% block body %}
    <section>
        <h2>Fiche stage</h2>
    </section>

    <section>
        <h3>Informations generales</h3>
        <table>
            <tbody>
                <tr>
                    <th>Étudiant</th>
                    <td title="{{ internship.student.major.label }}">{{ internship.student.fullName }} ({{ internship.student.major.code }})</td>
                </tr>
                <tr>
                    <th>Entreprise</th>
                    <td>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_company_show', {'id': internship.company.id}) }}">{{ internship.company.name }}</a>
                        {% else %}
                            {{ internship.company.name }}
                        {% endif %}
                        - {{ internship.company.city }}
                    </td>
                </tr>
                <tr>
                    <th>Periode</th>
                    <td>Du {{ internship.startDate ? internship.startDate|date('d/m/Y') : 'N/C' }} au {{ internship.endDate ? internship.endDate|date('d/m/Y') : 'N/C' }}</td>
                </tr>
                <tr>
                    <th>Suivi</th>
                    <td title="{{ internship.trackingTeacher ? internship.trackingTeacher.fullName : '' }}">{{ internship.trackingTeacher ? internship.trackingTeacher.trigram : 'Non affecte' }}</td>
                </tr>
                <tr>
                    <th>Visite</th>
                    <td title="{{ internship.visitingTeacher ? internship.visitingTeacher.fullName : '' }}">{{ internship.visitingTeacher ? internship.visitingTeacher.trigram : 'Non affecte' }}</td>
                </tr>
                <tr>
                    <th>Remarques</th>
                    <td>{{ internship.remarks|default('-') }}</td>
                </tr>
            </tbody>
        </table>
    </section>

    <section>
        <h3>Historique</h3>
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Auteur</th>
                    <th>Action</th>
                    <th>Ancien</th>
                    <th>Nouveau</th>
                </tr>
            </thead>
            <tbody>
                {% for log in internship.historyLogs %}
                    <tr>
                        <td>{{ log.createdAt|date('d/m/Y H:i') }}</td>
                        <td>{{ log.author.fullName }}</td>
                        <td>{{ log.actionType.label }}</td>
                        <td>{{ log.oldValue|default('-') }}</td>
                        <td>{{ log.newValue|default('-') }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucune modification enregistrée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
