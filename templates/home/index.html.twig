{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block stylesheets %}
    <style>
        .home-center-col,
        .home-milestone-col {
            text-align: center;
            white-space: nowrap;
        }

        .home-milestone-col {
            width: 7%;
            padding-block: 0 !important;
            line-height: 1;
        }

        .home-right-group-start {
            padding-inline-start: var(--space-8);
        }
    </style>
{% endblock %}

{% block body %}
    <section>
        <form method="get" action="{{ path('app_home_index') }}" style="margin-bottom: var(--space-4);">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div data-field style="flex: 1; min-width: 220px;">
                    <select id="major" name="major" aria-label="Filtrer par option" style="width: 100%;">
                        <option value="">Toutes les options</option>
                        {% for major in majors %}
                            <option value="{{ major.id }}" {{ (current_filters.major|default('')) == major.id ? 'selected' : '' }}>
                                {{ major.code }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div data-field style="flex: 1; min-width: 220px;">
                    <select id="teacher" name="teacher" aria-label="Filtrer par enseignant" style="width: 100%;">
                        <option value="">Tous les enseignants</option>
                        {% for teacher in teachers %}
                            <option value="{{ teacher.id }}" {{ (current_filters.teacher|default('')) == teacher.id ? 'selected' : '' }}>
                                {{ teacher.firstName }} {{ teacher.lastName }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div style="display: flex; align-items: center; gap: 1rem;">
                <button class="outline" type="submit">Filtrer</button>

                <a class="button outline" href="{{ path('app_home_index') }}">Réinitialiser</a>

                {% if is_granted('ROLE_SECRETARY') %}
                    <a class="button outline" href="{{ path('app_home_export', {'major': current_filters.major|default(''), 'teacher': current_filters.teacher|default('')}) }}">
                        Exporter CSV
                    </a>
                {% endif %}
            </div>
        </form>
    </section>

    <section class="table">
        <table>
            <thead>
                <tr>
                    <th>Étudiant</th>
                    <th class="home-center-col">Option</th>
                    <th>Entreprise</th>
                    <th class="home-center-col">Suivi</th>
                    <th class="home-center-col">Visite</th>
                    <th class="home-milestone-col home-right-group-start">Bilan</th>
                    <th class="home-milestone-col">Jury</th>
                    <th class="home-milestone-col">Attestation</th>
                    <th class="home-milestone-col">Remerciement</th>
                </tr>
            </thead>
            <tbody>
            {% for internship in internships %}
                <tr>
                    <td>{{ internship.student.fullName }}</td>
                    <td class="home-center-col">
                        <span title="{{ internship.student.major.label }}">
                            {{ internship.student.major.code }}
                        </span>
                    </td>
                    <td>{{ internship.company.name }} ({{ internship.company.city }})</td>
                    <td class="home-center-col">
                        <span title="{{ internship.trackingTeacher ? internship.trackingTeacher.fullName : '' }}">
                            {{ internship.trackingTeacher ? internship.trackingTeacher.trigram : 'Aucun' }}
                        </span>
                    </td>
                    <td class="home-center-col">
                        <span title="{{ internship.visitingTeacher ? internship.visitingTeacher.fullName : '' }}">
                            {{ internship.visitingTeacher ? internship.visitingTeacher.trigram : 'Aucun' }}
                        </span>
                    </td>
                    {% for item in internship.milestones %}
                        <td class="home-milestone-col {{ loop.first ? 'home-right-group-start' : '' }}">
                            {% if is_granted('EDIT_MILESTONE', item) %}
                                <a href="{{ path('app_milestone_edit', {'id': item.id}) }}" title="{{ item.status.label }}">
                                    {{ include('milestone/_status_icon.html.twig', {'status': item.status, 'comment': item.comment}) }}
                                </a>
                            {% else %}
                                {{ include('milestone/_status_icon.html.twig', {'status': item.status, 'comment': item.comment}) }}
                            {% endif %}
                        </td>
                    {% endfor %}
                </tr>
            {% else %}
                <tr>
                    <td colspan="9">Aucun stage ne correspond aux filtres.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>

    {{ include('_pagination.html.twig', {
        route: 'app_home_index',
        current_page: current_page,
        pages_count: pages_count,
        query: current_filters
    }) }}
{% endblock %}
