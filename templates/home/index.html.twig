{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <section>
        <form method="get" action="{{ path('app_home_index') }}">
            <div data-field>
                <label for="major">Option</label>
                <select id="major" name="major" aria-label="Filtrer par option">
                    <option value="">Toutes les options</option>
                    {% for major in majors %}
                        <option value="{{ major.id }}" {{ (current_filters.major|default('')) == major.id ? 'selected' }}>{{ major.code }}</option>
                    {% endfor %}
                </select>
            </div>

            <div data-field>
                <label for="teacher">Enseignant</label>
                <select id="teacher" name="teacher" aria-label="Filtrer par enseignant">
                    <option value="">Tous les enseignants</option>
                    {% for teacher in teachers %}
                        <option value="{{ teacher.id }}" {{ (current_filters.teacher|default('')) == teacher.id ? 'selected' }}>{{ teacher.firstName }} {{ teacher.lastName }}</option>
                    {% endfor %}
                </select>
            </div>

            <button type="submit">Filtrer</button>
            <a href="{{ path('app_home_index') }}">Réinitialiser</a>
            {% if is_granted('ROLE_SECRETARY') %}
                <a href="{{ path('app_home_export', {'major': current_filters.major|default(''), 'teacher': current_filters.teacher|default('')}) }}">Exporter CSV</a>
            {% endif %}
        </form>
    </section>

    <section class="table">
        <table>
            <thead>
                <tr>
                    <th>Étudiant</th>
                    <th>Option</th>
                    <th>Entreprise</th>
                    <th>Suivi</th>
                    <th>Visite</th>
                    <th style="text-align: right;">Bilan</th>
                    <th style="text-align: right;">Jury</th>
                    <th style="text-align: right;">Attestation</th>
                    <th style="text-align: right;">Remerciement</th>
                </tr>
            </thead>
            <tbody>
            {% for internship in internships %}
                <tr>
                    <td>{{ internship.student.fullName }}</td>
                    <td title="{{ internship.student.major.label }}">{{ internship.student.major.code }}</td>
                    <td>{{ internship.company.name }} ({{ internship.company.city }})</td>
                    <td title="{{ internship.trackingTeacher ? internship.trackingTeacher.fullName : '' }}">{{ internship.trackingTeacher ? internship.trackingTeacher.trigram : 'Aucun' }}</td>
                    <td title="{{ internship.visitingTeacher ? internship.visitingTeacher.fullName : '' }}">{{ internship.visitingTeacher ? internship.visitingTeacher.trigram : 'Aucun' }}</td>
                    {% for item in internship.milestones %}
                        <td style="text-align: right;">
                            {% if is_granted('EDIT_MILESTONE', item) %}
                                <a href="{{ path('app_milestone_edit', {'id': item.id}) }}" title="{{ item.status.label }}">
                                    {{ include('milestone/_status_icon.html.twig', {'status': item.status, 'comment': item.comment}) }}
                                </a>
                            {% else %}
                                {{ include('milestone/_status_icon.html.twig', {'status': item.status, 'comment': item.comment}) }}
                            {% endif %}
                        </td>
                    {% endfor %}
                </tr>
            {% else %}
                <tr>
                    <td colspan="9">Aucun stage ne correspond aux filtres.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>

    <section>
        <nav aria-label="Pagination">
                <menu class="buttons">
                    <li>
                        {% if current_page > 1 %}
                            <a href="{{ path('app_home_index', current_filters|merge({'page': current_page - 1})) }}" class="button outline small">&larr;</a>
                        {% else %}
                            <a class="button outline small" aria-disabled="true">&larr;</a>
                        {% endif %}
                    </li>

                    {% for i in 1..pages_count %}
                        <li>
                            {% if i == current_page %}
                                <a href="{{ path('app_home_index', current_filters|merge({'page': i})) }}" class="button small" aria-current="page">{{ i }}</a>
                            {% else %}
                                <a href="{{ path('app_home_index', current_filters|merge({'page': i})) }}" class="button outline small">{{ i }}</a>
                            {% endif %}
                        </li>
                    {% endfor %}

                    <li>
                        {% if current_page < pages_count %}
                            <a href="{{ path('app_home_index', current_filters|merge({'page': current_page + 1})) }}" class="button outline small">&rarr;</a>
                        {% else %}
                            <a class="button outline small" aria-disabled="true">&rarr;</a>
                        {% endif %}
                    </li>
                </menu>
            </nav>
    </section>
{% endblock %}
