{% extends 'base.html.twig' %}

{% block title %}Suivi et Visite des Stages{% endblock %}

{% block body %}
    <section>
        <h2>Tableau de bord des stages</h2>
    </section>

    <section>
        <form method="get" action="{{ path('app_home_index') }}">
            <label for="major">Option</label>
            <select id="major" name="major">
                <option value="">Toutes les options</option>
                {% for major in majors %}
                    <option value="{{ major.id }}" {{ (current_filters.major|default('')) == major.id ? 'selected' }}>{{ major.code }}</option>
                {% endfor %}
            </select>

            <label for="teacher">Enseignant</label>
            <select id="teacher" name="teacher">
                <option value="">Tous les enseignants</option>
                {% for teacher in teachers %}
                    <option value="{{ teacher.id }}" {{ (current_filters.teacher|default('')) == teacher.id ? 'selected' }}>{{ teacher.firstName }} {{ teacher.lastName }}</option>
                {% endfor %}
            </select>

            <button type="submit">Filtrer</button>
            <a href="{{ path('app_home_index') }}">Réinitialiser</a>
            {% if is_granted('ROLE_SECRETARY') %}
                <a href="{{ path('app_home_export', {'major': current_filters.major|default(''), 'teacher': current_filters.teacher|default('')}) }}">Exporter CSV</a>
            {% endif %}
        </form>
    </section>

    <section>
        <table>
            <thead>
                <tr>
                    <th>Étudiant</th>
                    <th>Option</th>
                    <th>Entreprise</th>
                    <th>Suivi</th>
                    <th>Visite</th>
                    <th>Remerciement</th>
                    <th>Bilan</th>
                    <th>Jury</th>
                    <th>Attestation</th>
                </tr>
            </thead>
            <tbody>
            {% for internship in internships %}
                <tr>
                    <td>{{ internship.student.lastName|upper }} {{ internship.student.firstName }}</td>
                    <td title="{{ internship.student.major.label }}">{{ internship.student.major.code }}</td>
                    <td>{{ internship.company.name }} ({{ internship.company.city }})</td>
                    <td title="{{ internship.trackingTeacher ? internship.trackingTeacher.fullName : '' }}">{{ internship.trackingTeacher ? internship.trackingTeacher.trigram : 'Non affecte' }}</td>
                    <td title="{{ internship.visitingTeacher ? internship.visitingTeacher.fullName : '' }}">{{ internship.visitingTeacher ? internship.visitingTeacher.trigram : 'Non affecte' }}</td>
                    {% for item in internship.milestones %}
                        <td>
                            {% if is_granted('EDIT_MILESTONE', item) %}
                                <a href="{{ path('app_milestone_edit', {'id': item.id}) }}" title="{{ item.status.label }}">{{ include('milestone/_status_icon.html.twig', {'status': item.status, 'comment': item.comment}) }}</a>
                            {% else %}
                                {{ include('milestone/_status_icon.html.twig', {'status': item.status, 'comment': item.comment}) }}
                            {% endif %}
                        </td>
                    {% endfor %}
                </tr>
            {% else %}
                <tr>
                    <td colspan="9">Aucun stage ne correspond aux filtres.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <p>Total: {{ total_items }} dossiers.</p>
    </section>

    <section>
        <p>
            {% if pages_count > 1 %}
                Pages:
                {% for i in 1..pages_count %}
                    {% if i == current_page %}
                        <strong>{{ i }}</strong>
                    {% else %}
                        <a href="{{ path('app_home_index', current_filters|merge({'page': i, 'limit': current_limit})) }}">{{ i }}</a>
                    {% endif %}
                {% endfor %}
            {% else %}
                Une seule page.
            {% endif %}
        </p>
        <p>
            Lignes par page:
            <a href="{{ path('app_home_index', current_filters|merge({'limit': 10})) }}">10</a>
            <a href="{{ path('app_home_index', current_filters|merge({'limit': 20})) }}">20</a>
            <a href="{{ path('app_home_index', current_filters|merge({'limit': 50})) }}">50</a>
        </p>
    </section>
{% endblock %}
