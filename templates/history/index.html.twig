{% extends 'base.html.twig' %}

{% block title %}Historique{% endblock %}

{% block body %}
    <section class="table">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Auteur</th>
                    <th>Action</th>
                    <th>Étudiant</th>
                    <th>Entreprise</th>
                    <th>Ancien</th>
                    <th>Nouveau</th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    <tr>
                        <td>{{ log.createdAt|date('d/m/Y H:i') }}</td>
                        <td>{{ log.author.fullName }}</td>
                        <td>{{ log.actionType.label }}</td>
                        <td>{{ log.internship ? log.internship.student.fullName : 'N/A' }}</td>
                        <td>{{ log.internship ? log.internship.company.name : 'N/A' }}</td>
                        <td>{{ log.oldValue|default('-') }}</td>
                        <td>{{ log.newValue|default('-') }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7">Aucun évènement.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section style="padding-top: var(--space-4);">
        <nav aria-label="Pagination">
            <menu class="buttons">
                <li>
                    {% if current_page > 1 %}
                        <a href="{{ path('app_history_index', {'page': current_page - 1}) }}" class="button outline small">&larr;</a>
                    {% else %}
                        <a class="button outline small" aria-disabled="true">&larr;</a>
                    {% endif %}
                </li>

                {% for i in 1..pages_count %}
                    <li>
                        {% if i == current_page %}
                            <a href="{{ path('app_history_index', {'page': i}) }}" class="button small" aria-current="page">{{ i }}</a>
                        {% else %}
                            <a href="{{ path('app_history_index', {'page': i}) }}" class="button outline small">{{ i }}</a>
                        {% endif %}
                    </li>
                {% endfor %}

                <li>
                    {% if current_page < pages_count %}
                        <a href="{{ path('app_history_index', {'page': current_page + 1}) }}" class="button outline small">&rarr;</a>
                    {% else %}
                        <a class="button outline small" aria-disabled="true">&rarr;</a>
                    {% endif %}
                </li>
            </menu>
        </nav>
    </section>
{% endblock %}
