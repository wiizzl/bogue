{% extends 'base.html.twig' %}

{% block title %}Historique{% endblock %}

{% block body %}
    <section class="table">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Auteur</th>
                    <th>Action</th>
                    <th>Dossier concerné</th>
                    <th>Détails</th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    <tr>
                        <td>{{ log.createdAt|date('d/m/Y H:i') }}</td>
                        <td>{{ log.author.fullName }}</td>
                        <td>{{ log.actionType.label }}</td>
                        <td>
                            {% if log.internship %}
                                {{ log.internship.student.fullName }} - {{ log.internship.company.name }}
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            Ancien: {{ log.oldValue|default('-') }}<br>
                            Nouveau: {{ log.newValue|default('-') }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucun évènement.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section>
        {% if pages_count > 1 %}
            <nav aria-label="Pagination">
                <menu class="buttons">
                    <li>
                        {% if current_page > 1 %}
                            <a href="{{ path('app_history_index', {'page': current_page - 1}) }}" class="button outline small">&larr; Précédent</a>
                        {% else %}
                            <span class="button outline small" aria-disabled="true">&larr; Précédent</span>
                        {% endif %}
                    </li>

                    {% for i in 1..pages_count %}
                        <li>
                            {% if i == current_page %}
                                <a href="{{ path('app_history_index', {'page': i}) }}" class="button small" aria-current="page">{{ i }}</a>
                            {% else %}
                                <a href="{{ path('app_history_index', {'page': i}) }}" class="button outline small">{{ i }}</a>
                            {% endif %}
                        </li>
                    {% endfor %}

                    <li>
                        {% if current_page < pages_count %}
                            <a href="{{ path('app_history_index', {'page': current_page + 1}) }}" class="button outline small">Suivant &rarr;</a>
                        {% else %}
                            <span class="button outline small" aria-disabled="true">Suivant &rarr;</span>
                        {% endif %}
                    </li>
                </menu>
            </nav>
        {% else %}
            <p>Une seule page.</p>
        {% endif %}
    </section>
{% endblock %}
