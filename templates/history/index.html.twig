{% extends 'base.html.twig' %}

{% block title %}Journal d'Audit Global{% endblock %}

{% block body %}
    <section>
        <h2>Journal d'audit</h2>
    </section>
    <section>
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Auteur</th>
                    <th>Action</th>
                    <th>Dossier concerné</th>
                    <th>Détails</th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    <tr>
                        <td>{{ log.createdAt|date('d/m/Y H:i') }}</td>
                        <td>{{ log.author.fullName }}</td>
                        <td>{{ log.actionType.label }}</td>
                        <td>
                            {% if log.internship %}
                                {{ log.internship.student.fullName }} - {{ log.internship.company.name }}
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            Ancien: {{ log.oldValue|default('-') }}<br>
                            Nouveau: {{ log.newValue|default('-') }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucun évènement.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section>
        <p>
            {% if pages_count > 1 %}
                {% for i in 1..pages_count %}
                    {% if i == current_page %}
                        <strong>{{ i }}</strong>
                    {% else %}
                        <a href="{{ path('app_history_index', {'page': i}) }}">{{ i }}</a>
                    {% endif %}
                {% endfor %}
            {% else %}
                Une seule page.
            {% endif %}
        </p>
    </section>
{% endblock %}
