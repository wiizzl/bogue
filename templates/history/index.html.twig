{% extends 'base.html.twig' %}

{% block title %}Journal d'Audit Global{% endblock %}

{% block body %}
    <h1>📜 Journal d'Audit (Traçabilité)</h1>

    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Auteur</th>
                <th>Action</th>
                <th>Dossier concerné</th>
                <th>Détails</th>
            </tr>
        </thead>
        <tbody>
            {% for log in logs %}
                <tr>
                    <td>{{ log.createdAt|date('d/m/Y H:i') }}</td>
                    <td>{{ log.author.firstName }} {{ log.author.lastName }}</td>
                    <td><strong>{{ log.actionType.label }}</strong></td>
                    <td>
                        {% if log.internship %}
                            {{ log.internship.student.lastName|upper }} - {{ log.internship.company.name }}
                        {% else %}
                            N/A
                        {% endif %}
                    </td>
                    <td>
                        <small>
                            Ancien : {{ log.oldValue|default('-') }}<br>
                            Nouveau : {{ log.newValue|default('-') }}
                        </small>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="pagination">
        {% for i in 1..pages_count %}
            <a href="{{ path('app_history_index', {'page': i}) }}"
               class="{{ i == current_page ? 'active' : '' }}">{{ i }}</a>
        {% endfor %}
    </div>
{% endblock %}
