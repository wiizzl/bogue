{% extends 'base.html.twig' %}

{% block title %}Entreprises{% endblock %}

{% block body %}
    <section>
        <a href="{{ path('app_company_new') }}">Ajouter une entreprise</a>
    </section>

    <section class="table">
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Tuteur</th>
                    <th>Téléphone</th>
                    <th>Email</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for company in companies %}
                <tr>
                    <td>{{ company.name }}</td>
                    <td>{{ company.city|default('-') }}</td>
                    <td>{{ company.tutorName|default('-') }}</td>
                    <td>{{ company.phone|default('-') }}</td>
                    <td>{{ company.email|default('-') }}</td>
                    <td style="display: flex; align-items: center; gap: var(--space-2);">
                        <a href="{{ path('app_company_show', {'id': company.id}) }}" class="button outline small" aria-label="Voir l'entreprise" title="Voir">
                            {{ ux_icon('eye') }}
                        </a>
                        <a href="{{ path('app_company_edit', {'id': company.id}) }}" class="button outline small" aria-label="Modifier l'entreprise" title="Modifier">
                            {{ ux_icon('pen-line') }}
                        </a>
                        {{ include('company/_delete_form.html.twig', {'company': company}) }}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Aucune entreprise enregistrée.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>

    <section style="padding-top: var(--space-4);">
        <nav aria-label="Pagination">
            <menu class="buttons">
                <li>
                    {% if current_page > 1 %}
                        <a href="{{ path('app_company_index', {'page': current_page - 1}) }}" class="button outline small">&larr;</a>
                    {% else %}
                        <a class="button outline small" aria-disabled="true">&larr;</a>
                    {% endif %}
                </li>

                {% for i in 1..pages_count %}
                    <li>
                        {% if i == current_page %}
                            <a href="{{ path('app_company_index', {'page': i}) }}" class="button small" aria-current="page">{{ i }}</a>
                        {% else %}
                            <a href="{{ path('app_company_index', {'page': i}) }}" class="button outline small">{{ i }}</a>
                        {% endif %}
                    </li>
                {% endfor %}

                <li>
                    {% if current_page < pages_count %}
                        <a href="{{ path('app_company_index', {'page': current_page + 1}) }}" class="button outline small">&rarr;</a>
                    {% else %}
                        <a class="button outline small" aria-disabled="true">&rarr;</a>
                    {% endif %}
                </li>
            </menu>
        </nav>
    </section>
{% endblock %}
