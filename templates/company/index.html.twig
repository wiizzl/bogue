{% extends 'base.html.twig' %}

{% block title %}Entreprises{% endblock %}

{% block body %}
    <section>
        <h2>Liste des entreprises</h2>
        <p><a href="{{ path('app_company_new') }}">Ajouter une entreprise</a></p>
    </section>

    <section>
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Contact</th>
                    <th>Telephone</th>
                    <th>Email</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for company in companies %}
                <tr>
                    <td>{{ company.name }}</td>
                    <td>{{ company.city|default('-') }}</td>
                    <td>{{ company.contactName|default('-') }}</td>
                    <td>{{ company.phone|default('-') }}</td>
                    <td>{{ company.email|default('-') }}</td>
                    <td>
                        <a href="{{ path('app_company_show', {'id': company.id}) }}" aria-label="Voir l'entreprise" title="Voir">
                            {{ ux_icon('eye') }}
                            <span>Voir</span>
                        </a>
                        <a href="{{ path('app_company_edit', {'id': company.id}) }}" aria-label="Modifier l'entreprise" title="Modifier">
                            {{ ux_icon('pen-line') }}
                            <span>Modifier</span>
                        </a>
                        {{ include('company/_delete_form.html.twig', {'company': company}) }}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Aucune entreprise enregistrée.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
