<form method="post" action="{{ path('app_company_delete', {'id': company.id}) }}" onsubmit="return confirm('Confirmer la suppression de cette entreprise ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ company.id) }}">
    <button class="button outline small" type="submit" aria-label="Supprimer l'entreprise" title="Supprimer">
        {{ ux_icon('trash-2') }}
    </button>
</form>
