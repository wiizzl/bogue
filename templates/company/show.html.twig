{% extends 'base.html.twig' %}

{% block title %}Entreprise{% endblock %}

{% block body %}
    <section>
        <h2>Fiche entreprise</h2>
    </section>

    <section>
        <table>
            <tbody>
                <tr>
                    <th>ID</th>
                    <td>{{ company.id }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ company.name }}</td>
                </tr>
                <tr>
                    <th>Adresse</th>
                    <td>{{ company.address|default('-') }}</td>
                </tr>
                <tr>
                    <th>Code postal</th>
                    <td>{{ company.zipCode|default('-') }}</td>
                </tr>
                <tr>
                    <th>Ville</th>
                    <td>{{ company.city|default('-') }}</td>
                </tr>
                <tr>
                    <th>Contact</th>
                    <td>{{ company.contactName|default('-') }}</td>
                </tr>
                <tr>
                    <th>Telephone</th>
                    <td>{{ company.phone|default('-') }}</td>
                </tr>
                <tr>
                    <th>Email</th>
                    <td>{{ company.email|default('-') }}</td>
                </tr>
            </tbody>
        </table>
    </section>
{% endblock %}
