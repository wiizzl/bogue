{% extends 'base.html.twig' %}

{% block title %}Étudiants{% endblock %}

{% block body %}
    <section>
        <a href="{{ path('app_student_new') }}">Ajouter un étudiant</a>
        <form method="get" action="{{ path('app_student_index') }}">
            <label data-field for="showArchived">
                <input id="showArchived" name="showArchived" type="checkbox" value="1" {% if showArchived %}checked{% endif %}>
                Afficher les archivés
            </label>
            <button type="submit">Filtrer</button>
        </form>
    </section>

    <section class="table">
        <table>
            <thead>
                <tr>
                    <th>Prénom</th>
                    <th>Nom</th>
                    <th>Promotion</th>
                    <th>Option</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for student in students %}
                <tr>
                    <td>{{ student.firstName }}</td>
                    <td>{{ student.lastName }}</td>
                    <td>{{ student.promotion.year }}</td>
                    <td title="{{ student.major.label }}">{{ student.major.code }}</td>
                    <td style="display: flex; align-items: center; gap: var(--space-2);">
                        <a href="{{ path('app_student_edit', {'id': student.id}) }}" class="button outline small" aria-label="Modifier l'étudiant" title="Modifier">
                            {{ ux_icon('pen-line') }}
                        </a>
                        {{ include('student/_delete_form.html.twig', {'student': student}) }}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Aucun étudiant enregistré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>

    <section style="padding-top: var(--space-4);">
        <nav aria-label="Pagination">
            <menu class="buttons">
                {% set pagination_params = showArchived ? {'showArchived': 1} : {} %}

                <li>
                    {% if current_page > 1 %}
                        <a href="{{ path('app_student_index', pagination_params|merge({'page': current_page - 1})) }}" class="button outline small">&larr;</a>
                    {% else %}
                        <a class="button outline small" aria-disabled="true">&larr;</a>
                    {% endif %}
                </li>

                {% for i in 1..pages_count %}
                    <li>
                        {% if i == current_page %}
                            <a href="{{ path('app_student_index', pagination_params|merge({'page': i})) }}" class="button small" aria-current="page">{{ i }}</a>
                        {% else %}
                            <a href="{{ path('app_student_index', pagination_params|merge({'page': i})) }}" class="button outline small">{{ i }}</a>
                        {% endif %}
                    </li>
                {% endfor %}

                <li>
                    {% if current_page < pages_count %}
                        <a href="{{ path('app_student_index', pagination_params|merge({'page': current_page + 1})) }}" class="button outline small">&rarr;</a>
                    {% else %}
                        <a class="button outline small" aria-disabled="true">&rarr;</a>
                    {% endif %}
                </li>
            </menu>
        </nav>
    </section>
{% endblock %}
