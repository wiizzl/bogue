{% extends 'base.html.twig' %}

{% block title %}Étudiant — {{ student.firstName }} {{ student.lastName }}{% endblock %}

{% block body %}
    <section>
        <h2>Fiche étudiant</h2>
        <p>{{ student.lastName|upper }} {{ student.firstName }}</p>
    </section>

    <section>
        <table>
            <tbody>
                <tr>
                    <th>Option</th>
                    <td>{{ student.major.label }} ({{ student.major.code }})</td>
                </tr>
                <tr>
                    <th>Promotion</th>
                    <td>{{ student.promotion.year }}</td>
                </tr>
            </tbody>
        </table>
    </section>

    <section>
        <a href="{{ path('app_student_edit', {'id': student.id}) }}">Modifier</a>
        <a href="{{ path('app_student_index') }}">Retour a la liste</a>
    </section>
{% endblock %}
