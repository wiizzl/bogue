{% import "_form_macros.html.twig" as forms %}

{{ form_start(form) }}
    <fieldset>
        <label data-field for="{{ form.year.vars.id }}">
            {{ forms.label(form.year) }}
            {{ form_widget(form.year) }}
            {{ form_errors(form.year) }}
        </label>

        <label data-field for="{{ form.isArchived.vars.id }}">
            {{ form_widget(form.isArchived) }}
            {{ forms.label(form.isArchived) }}
            {{ form_errors(form.isArchived) }}
        </label>
    </fieldset>
    <button type="submit">Enregistrer</button>
{{ form_end(form) }}
