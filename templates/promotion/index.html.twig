{% extends 'base.html.twig' %}

{% block title %}Promotions{% endblock %}

{% block body %}
    <section>
        <h2>Promotions</h2>
        <p><a href="{{ path('app_promotion_new') }}">Ajouter une promotion</a></p>
    </section>

    <section>
        <table>
            <thead>
                <tr>
                    <th>Année</th>
                    <th>Statut</th>
                    <th>Étudiants</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for promotion in promotions %}
                <tr>
                    <td>{{ promotion.year }}</td>
                    <td>{{ promotion.isArchived ? 'Archivée' : 'Active' }}</td>
                    <td>{{ promotion.students|length }}</td>
                    <td>
                        <a href="{{ path('app_promotion_edit', {'id': promotion.id}) }}" aria-label="Modifier la promotion" title="Modifier">
                            {{ ux_icon('pen-line') }}
                            <span>Modifier</span>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">Aucune promotion enregistrée.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
