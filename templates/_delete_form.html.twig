<form method="post" action="{{ path(route, {'id': entity.id}) }}" onsubmit="return confirm(confirm_message);">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entity.id) }}">
    <button class="button outline small" type="submit" aria-label="{{ aria_label }}" title="Supprimer">
        {{ ux_icon('trash-2') }}
    </button>
</form>
