SERVER_NAME=:80
HTTP_PORT=8080
HTTPS_PORT=8443
HTTP3_PORT=8443

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL=mysql://${MYSQL_USER:-app}:${MYSQL_PASSWORD:-!ChangeMe!}@database:3306/${MYSQL_DATABASE:-app}?serverVersion=${MYSQL_VERSION:-8.0.45}&charset=${MYSQL_CHARSET:-utf8mb4}
###< doctrine/doctrine-bundle ###
